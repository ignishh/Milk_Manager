    <path
        android:name="dot_mid"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M 11.95,12 L 12.05,12"/>

    <path
        android:name="dot_bottom"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M 11.95,19 L 12.05,19"/>
    
</vector>
